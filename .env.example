# ServiceNow instance credentials for schema validation
# Copy to .env and fill in — .env is gitignored, never commit it

# Instance hostname only — no https://, no trailing slash
SN_INSTANCE=dev12345.service-now.com

# Auth — choose one method:

# Option A: basic auth
SN_USERNAME=admin
SN_PASSWORD=

# Option B: API token (preferred for service accounts)
# SN_TOKEN=

# RAG service config (optional overrides)
# RAG_PORT=8765
# OLLAMA_API=http://localhost:11434
# MAIN_MODEL=deepseek-coder-v2:16b-lite-instruct-q4_K_M
